# ───────────────────────────────────────────────
# server-watchdog — .env.watchdog.example
# Copy to .env.watchdog and fill in your values.
# chmod 600 .env.watchdog  ← ALWAYS keep this file owner-readable only
# NEVER commit .env.watchdog to any repository.
# ───────────────────────────────────────────────

# ── Target project ───────────────────────────────────────────────────
# Absolute path to the project root on this server
WATCHDOG_PROJECT_ROOT=/var/www/myapp

# Absolute path to the backend error log file to watch
# Supports any log format — errors are extracted by classifier.js
WATCHDOG_LOG_PATH=/var/www/myapp/logs/error.log

# ── Git ──────────────────────────────────────────────────────────────
# Branch that fix branches are based off (should be your main/production branch)
WATCHDOG_GIT_BRANCH=main

# Prefix for AI-generated fix branches
# Result: ai-fix/ER_BAD_FIELD_ERROR-20260607-1430
WATCHDOG_GIT_FIX_BRANCH_PREFIX=ai-fix

# Git remote name (usually 'origin')
WATCHDOG_GIT_REMOTE=origin

# ── AI Agent ─────────────────────────────────────────────────────────
# Gemini API key (get one at https://aistudio.google.com/app/apikeys)
# Use a PAYG key for production — free tier is limited to 5 RPM
GEMINI_API_KEY=

# Gemini model to use
# gemini-2.5-flash  — fast, cost-effective (recommended)
# gemini-2.5-pro    — more capable, higher cost, requires PAYG
AI_FIX_MODEL=gemini-2.5-flash

# Confidence threshold to commit a fix (0.0 – 1.0)
# Fixes below this threshold are logged but not committed
AI_FIX_COMMIT_THRESHOLD=0.80

# Max times the agent retries a fix if the verification test fails
AI_FIX_MAX_RETRIES=2

# ── Timing ───────────────────────────────────────────────────────────
# How often to poll the log file (milliseconds)
# Default: 60000 (60 seconds)
WATCHDOG_POLL_MS=60000

# Error deduplication window — errors within this window are batched
# into a single agent invocation (milliseconds)
# Default: 60000 (same as poll interval)
WATCHDOG_DEDUP_WINDOW_MS=60000

# After fixing an error, ignore the same error code for this long
# Prevents the agent from re-fixing the same bug repeatedly (milliseconds)
# Default: 300000 (5 minutes)
WATCHDOG_COOLDOWN_MS=300000

# PM2 restart-delay if watchdog itself crashes (milliseconds)
WATCHDOG_RESPAWN_DELAY_MS=5000

# ── Process manager ──────────────────────────────────────────────────
# How to restart your backend after a fix is applied
# Options: pm2 | systemd | docker | docker-compose
WATCHDOG_RESTART_MODE=pm2

# PM2: app name as shown in `pm2 list`
WATCHDOG_PM2_APP_NAME=server-myapp

# systemd: service name as in `systemctl status <name>`
# WATCHDOG_SYSTEMD_SERVICE=myapp

# docker: container name as in `docker ps`
# WATCHDOG_DOCKER_CONTAINER=myapp-backend

# docker-compose: path to compose file and service name
# WATCHDOG_DOCKER_COMPOSE_FILE=/var/www/myapp/docker-compose.yml
# WATCHDOG_DOCKER_COMPOSE_SERVICE=backend

# ── Health verification ───────────────────────────────────────────────
# URL that returns {"status":"ok"} (or HTTP 200) after a successful restart
# The watchdog hits this after every restart to confirm the fix didn't break things
WATCHDOG_HEALTH_URL=https://myapp.com/api/health

# How long to wait for the health endpoint after restart (milliseconds)
WATCHDOG_HEALTH_TIMEOUT_MS=15000

# How many times to retry the health check before declaring failure
WATCHDOG_HEALTH_RETRIES=3

# ── Project-specific AI knowledge ────────────────────────────────────
# Path to your project's AGENT.md, copilot-instructions.md, or equivalent
# The AI reads this before every fix attempt — include architecture, patterns,
# which errors are fixable vs. which need human review, and deployment context
# WATCHDOG_AGENT_MD=/var/www/myapp/AGENT.md

# Optional: additional skills/context file injected into the agent system prompt
# WATCHDOG_EXTRA_SKILLS=/var/www/myapp/watchdog-skills.md

# ── Notifications ────────────────────────────────────────────────────
# Slack/Discord/generic webhook — POST with JSON payload on fix events
# WATCHDOG_NOTIFY_WEBHOOK=https://hooks.slack.com/services/xxx

# ── Test execution ───────────────────────────────────────────────────
# Maximum time agent-written verification tests may run (milliseconds)
WATCHDOG_TEST_TIMEOUT_MS=30000

# Whether to include agent-written tests in the fix commit as regression tests
WATCHDOG_COMMIT_TESTS=true
